PORT=4000
HOST=0.0.0.0
MONGODB_URI=mongodb://127.0.0.1:27017/meevo
# Exemple Atlas : mongodb+srv://<user>:<password>@cluster0.mongodb.net/meevo?retryWrites=true&w=majority
JWT_SECRET=change_this_secret
CLIENT_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
PARTNER_MONTHLY_PRICE=50000
PARTNER_MAX_SUBSCRIPTION_MONTHS=24
BOOKING_PLATFORM_COMMISSION_RATE=0.05
BOOKING_PAYMENT_HOLD_MINUTES=15
# Paiement CinetPay (PayIn)
CINETPAY_APIKEY=
CINETPAY_SITE_ID=
# URL publique (obligatoire si tu veux recevoir les callbacks automatiquement)
# Exemple: https://api.meevo.tg/api/subscriptions/cinetpay/notify
CINETPAY_NOTIFY_URL=
# URL de retour apres paiement (web / deep link)
CINETPAY_RETURN_URL=
CINETPAY_CURRENCY=XOF
CINETPAY_LANG=fr
CINETPAY_CHANNELS=MOBILE_MONEY

# Payout CinetPay (PayOut / transfert)
CINETPAY_PAYOUT_PASSWORD=
CINETPAY_PAYOUT_NOTIFY_URL=
CINETPAY_PAYOUT_PREFIX=228
